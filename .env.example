PORT=8787
SCRIBE_MODE=hybrid
APP_ENV=development
PUBLIC_BASE_URL=
API_BEARER_TOKEN=
CLIENT_AUTH_STATE_FILE=./data/client-access.json
CLIENT_TRIAL_MAX_REQUESTS=20
CLIENT_TRIAL_MAX_AUDIO_SECONDS=1200
CLIENT_TRIAL_MAX_ESTIMATED_COST_USD=2.5
CLIENT_BOOTSTRAP_PER_IP_PER_HOUR=10
CLIENT_BOOTSTRAP_PER_INSTALL_PER_DAY=3
CLIENT_ESTIMATED_COST_PER_AUDIO_MINUTE_USD=0.08
CLIENT_REQUIRE_ATTESTATION=false
SETTINGS_FILE=./data/settings.json
ENABLE_SETTINGS_WRITE=true
MAX_REQUEST_BYTES=67108864
DEFAULT_NOTE_STYLE=soap
DEFAULT_SPECIALTY=primary-care
ENABLE_WEB_UI=true
ENABLE_SETTINGS_UI=true
PHI_REDACTION_MODE=basic
REDACT_BEFORE_API_CALLS=true
AUDIT_LOG_FILE=./data/audit.log

# Provider choices
# Transcription: mock, openai, whisper.cpp, faster-whisper, deepgram, google, berget
# Note generation: mock, openai, anthropic, gemini, ollama
TRANSCRIPTION_PROVIDER=mock
NOTE_PROVIDER=mock

# --- OpenAI (LLM + transcription) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_NOTE_MODEL=gpt-4.1-mini
# Tip: Set OPENAI_BASE_URL to use OpenAI-compatible services:
#   vLLM:       http://localhost:8000
#   llama.cpp:  http://localhost:8080
#   LiteLLM:    http://localhost:4000
#   Together:   https://api.together.xyz
#   Groq:       https://api.groq.com/openai

# --- Anthropic Claude (LLM) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Gemini (LLM) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=180000

# --- Deepgram (transcription) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3-medical

# --- Google Cloud Speech (transcription) ---
GOOGLE_SPEECH_API_KEY=
GOOGLE_SPEECH_MODEL=latest_long

# --- Berget AI (transcription, EU sovereign) ---
BERGET_API_KEY=
BERGET_BASE_URL=https://api.berget.ai
BERGET_TRANSCRIBE_MODEL=KBLab/kb-whisper-large
BERGET_NOTE_MODEL=openai/gpt-oss-120b

# --- Local whisper.cpp / faster-whisper (transcription) ---
WHISPER_LOCAL_COMMAND=
LOCAL_TRANSCRIBE_TIMEOUT_MS=120000
LOCAL_TRANSCRIBE_EXPECTS=stdin

# --- Streaming (real-time audio via WebSocket) ---
# Streaming providers: mock-stream, deepgram-stream, whisper-stream
STREAMING_TRANSCRIPTION_PROVIDER=mock-stream
STREAMING_WHISPER_MODEL=onnx-community/kb-whisper-large-ONNX
STREAMING_WHISPER_LANGUAGE=sv
STREAMING_WHISPER_INTERVAL_MS=3000

# --- Speaker diarization (pyannote sidecar, optional) ---
# Run: cd diarize && pip install -r requirements.txt && uvicorn server:app --port 8786
DIARIZE_SIDECAR_URL=http://localhost:8786
DIARIZE_ON_END=false
